{
  "expo": {
    "name": "Vexto",
    "slug": "vexto-app",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/logo/vexto.png",
    "scheme": "vextoapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "La cámara se usa para leer códigos de barras de los productos al vender.",
        "NSLocalNetworkUsageDescription": "Vexto accede al servidor en tu red local (Wi‑Fi) para sincronizar inventario y ventas.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.jeison5400.vextoapp"
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo/vexto.png",
        "backgroundImage": "./assets/logo/vexto.png",
        "monochromeImage": "./assets/logo/vexto.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.jeison5400.vextoapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/vexto.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Permite a Vexto usar la cámara para escanear códigos de barras al vender."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/vexto.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6cc1414f-7d80-4486-ac9d-6b4f0f6d70ab"
      }
    }
  }
}
